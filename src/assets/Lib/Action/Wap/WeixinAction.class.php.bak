	//获奖名单
	public function prize(){
		$id = $_REQUEST['id'];
		$list = M('wx_win')->where('win_date='.$id.' and is_del=0')->select();
		foreach($list as $key=>$value){
			$list[$key]['son'] = M('wx_win_name')->where('wid='.$value['id'])->select();
		}
		$this->assign('list',$list);
		$this->display();
	}
	
