class WeixinAction extends Action {
	public $user;
	public function _initialize(){
		header('Content-type: text/html; charset=utf-8');
		
		//百度统计
		import("@.ORG.BaiduHmWap");
		$_hmt = new _HMT("45988a729df28f554d96a5b9932b17e1");
		$_hmtPixel = $_hmt->trackPageView();
		$this->assign('BdWap',$_hmtPixel);
		
		$this->user['appid'] = 'wx9f98139e202c7003';
		$this->user['appsecret'] = 'fc569bb8896f29b5269fe49169d0c77a';
		
		//微信SDK
		vendor('Weixin.jssdk');
		$jssdk = new JSSDK($this->user['appid'],$this->user['appsecret']);
		$signPackage = $jssdk->GetSignPackage();
		$this->assign('signPackage',$signPackage);
