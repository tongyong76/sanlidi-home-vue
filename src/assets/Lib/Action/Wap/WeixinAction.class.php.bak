	//微信用甩卖
	public function tejia(){
		//获取用户openid
		$wx_openid = SESSION('wx_openid');
		if(!$wx_openid){
			$redirect_uri = "http%3A%2F%2Fm.33ly.com%2FWeixin%2Fslogin";
			$url = "https://open.weixin.qq.com/connect/oauth2/authorize?appid=".$this->user['appid']."&redirect_uri=".$redirect_uri."&response_type=code&scope=snsapi_base&state=STATE#wechat_redirect";
			header("Location: $url");
		}
		
		//商品信息
		$mod = M('sale_goods as sg');
		$info = $mod->field('*,sg.id as id')->join('33_goods as g on g.id=sg.gid')->where('sg.is_del=0')->order('sg.sale_start desc')->find();
		//var_dump($info);
		$this->assign('info',$info);
		SESSION('sgid',$info['id']);
		
		//所有参与人信息
		if($info){
			$mod = M('sale_order as so');
			$ulist = $mod->join('33_wx_user as wu on so.uid=wu.uid')->where('sgid='.$info['id'])->select();
			$this->assign('ulist',$ulist);
		}
		
		$this->display();
	}
	
	//特价抢购处理
	public function tejiaAct(){
		$mod = M('sale_order');
		
		//数据
		$data['gid'] = 517;
		$data['uid'] = rand(1,1000);
		$data['btime'] = time();
		$data['status'] = 1;
	
		$mod->add($data);
	}
	
	public function tips(){
		$wx_openid = SESSION('wx_openid');
		//$sgid = $_REQUEST['sgid']?trim($_REQUEST['sgid']):0;
		$sgid = SESSION('sgid');
		$is_uid = M('wx_user')->where('wx_openid="'.$wx_openid.'"')->getfield('uid');
		if($is_uid){
			if($sgid){
				//插入订单
				$data['sgid'] = $_REQUEST['sgid'];
				$data['uid'] = $is_uid;
				$data['btime'] = time();
				$data['status'] = 1;
				
				$smod = M('sale_goods as sg');
				$goodsInfo = $smod->join('33_goods as g on g.id=sg.gid')->field('g.name,g.subname,sg.sale_price')->where('sg.id='.$sgid)->find();
				
				//微信支付
				vendor('Weixin.WxPay.pub.config');
				vendor('Weixin.WxPayPubHelper');
				$jsApi = new JsApi_pub();	
				$openid = $wx_openid;
				//$openid = 'oOrekjmmExAQ40gRUAzM8I_LrnO8';
				// if (!isset($_GET['code']))
				// {
					// //触发微信返回code码
					// $url = $jsApi->createOauthUrlForCode(WxPayConf_pub::JS_API_CALL_URL);
					// Header("Location: $url"); 
				// }else
				// {
					// //获取code码，以获取openid
					// $code = $_GET['code'];
					// $jsApi->setCode($code);
					// $openid = $jsApi->getOpenId();
				// }
				//统一支付接口
				$unifiedOrder = new UnifiedOrder_pub();
				$unifiedOrder->setParameter("openid","$openid");
				$unifiedOrder->setParameter("body",$goodsInfo['name']);//商品描述
				$timeStamp = time();
				$out_trade_no = WxPayConf_pub::APPID."$timeStamp";
				$unifiedOrder->setParameter("out_trade_no","$out_trade_no");//商户订单号 
				$unifiedOrder->setParameter("total_fee",$goodsInfo['sale_price']*100);//总金额
				$unifiedOrder->setParameter("notify_url",WxPayConf_pub::NOTIFY_URL);//通知地址 
				$unifiedOrder->setParameter("trade_type","JSAPI");//交易类型
				
				$prepay_id = $unifiedOrder->getPrepayId();
				$jsApi->setPrepayId($prepay_id);
				$jsApiParameters = $jsApi->getParameters();
				$this->assign('jsApiParameters',$jsApiParameters);
				
				
				//防止反复参与
				$map_order['sgid'] = $data['sgid'];
				$map_order['uid'] = $data['uid'];
				$is_exist = M('sale_order')->where($map_order)->find();
				if(!$is_exist) M('sale_order')->add($data);	
			}
					
			//绑定，go tips1;
			$tips['title'] = '下单成功';
			$tips['data'] = '<p>1、抢购名额有限，仅限手机端支付，支付资格已下单时间为准</p>';
			$tips['data'] .= '<p>2、订单须在半小时内支付完成，付款成功则代表抢购成功，逾期未付款则表示您放弃抢购。</p>';
			$tips['data'] .= '<p>3、抢购产品价格仅限于“费用包含”中所列的费用，如有其他未含费用敬请自理。</p>';
			$tips['data'] .= '<p>4、抢购产品因资源特殊，支付成功后不得取消和退订。</p>';
//			echo $tips['data'];
			$tips['button_type'] = 1;
//			echo "go支付宝";
			
			//判断资格
		}else{
			$tips['title'] = '请先绑定帐号';
			$tips['data'] = '<p>1、抢购只针对三三旅游微信会员，如需参与请先绑定帐号</p>';
			$tips['data'] .= '<p>2、订单须在半小时内支付完成，付款成功则代表抢购成功，逾期未付款则表示您放弃抢购。</p>';
			$tips['data'] .= '<p>3、抢购产品价格仅限于“费用包含”中所列的费用，如有其他未含费用敬请自理。</p>';
			$tips['data'] .= '<p>4、抢购产品因资源特殊，支付成功后不得取消和退订。</p>';
			$tips['button_type'] = 2;
//			echo $tips['data'];
//			echo "<a href='http://m.33ly.com/User/login'>go绑定帐号</a>";
		}
		$this->assign('tips',$tips);
		$this->display();
	}
	
	
