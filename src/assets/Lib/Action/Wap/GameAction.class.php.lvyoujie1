	//活动首页
	//input wx_openid
    public function index(){
		//echo "<p>活动结束</p>";
		//js-sdk
		import("@.ORG.Jssdk");
		$jssdk = new JSSDK($this->wx_appid,$this->wx_appsecret);
		$signPackage = $jssdk->GetSignPackage();
		$this->assign('signPackage',$signPackage);
		
		//获取微信信息
		$wx_openid = 'oOrekjmmExAQ40gRUAzM8I_LrnO8';
		// $wx_openid = SESSION('wx_openid');
		// $wx_nickname = M('wx_user')->where('wx_openid="'.$wx_openid.'"')->getfield('wx_nickname');		
		// if(!$wx_openid or !$wx_nickname){
			// $redirect_uri = urlencode('http://m.33ly.com/Game/slogin');
			// //$state = base64_encode('http://m.33ly.com/Game/index');
			// $state = 0;
			// $url = "https://open.weixin.qq.com/connect/oauth2/authorize?appid=".$this->wx_appid."&redirect_uri=".$redirect_uri."&response_type=code&scope=snsapi_base&state=".$state."#wechat_redirect";
			// header("Location: $url");
		// }
		
		//初始化活动记录
		$recordInfo = M('wx_gamerecord')->where('from_user="'.$wx_openid.'" and to_user="'.$wx_openid.'"')->find(); 
		if(!$recordInfo['record_id']){						
			//插入记录
			$data['from_user'] = $wx_openid;
			$data['to_user'] = $wx_openid;
			$data['status'] = 1;
			$data['add_time'] = time();
			$newId = M('wx_gamerecord')->add($data);
			
			//初始化游戏信息
			$gidata['wx_openid'] = $wx_openid;
			$gidata['status'] = 1;
			$gidata['last_record'] = $newId;
			$newId = M('wx_gameinfo')->add($gidata);
			
			$this->assign('first',1);   //第一次提示
		}
		
		//根据wx_openid获得活动记录
		//当前状态status
		$myInfo = M('wx_user as u')->join('33_wx_gameinfo as gi on gi.wx_openid=u.wx_openid')->where('u.wx_openid="'.$wx_openid.'"')->find();
		switch($myInfo['status']){
			case 1:
				$myInfo['price'] = '哈哈一只';
				break;
			case 2:
				$myInfo['price'] = '第一个三';
				break;
			case 3:
				$myInfo['price'] = '第二个三';
				break;
			case 4:
				$myInfo['price'] = '嘻字';
				break;
			case 5:
				$myInfo['price'] = '游字';
				break;
			case 6:
				$myInfo['price'] = '季字';
				break;
		}
		$this->assign('myInfo',$myInfo);
		
		//奖品
		$priceList = M('wx_gameprice')->where('price_status <> 1')->order('price_status desc')->select();
		$this->assign('priceList',$priceList);
		
		//全部记录
		$allRecord = M('wx_gamerecord as gr')
		->field('record_id,status,is_update,add_time,u1.wx_nickname as from_user_nickname,u1.wx_headimgurl as from_user_headimgurl,u1.local_headimgurl as from_user_local_headimgurl,u2.wx_nickname as to_user_nickname,u2.wx_headimgurl as to_user_headimgurl,u2.local_headimgurl as to_user_local_headimgurl')
		->join('33_wx_user as u1 on u1.wx_openid=gr.from_user')
		->join('33_wx_user as u2 on u2.wx_openid=gr.to_user')
		->where('to_user <> from_user')
		->order('record_id desc')
		->limit(30)
		->select();
		foreach($allRecord as $key=>$value){
			switch($value['status']){
				case 1:
					$allRecord[$key]['des'] = '"哈哈一只"';
					break;
				case 2:
					$allRecord[$key]['des'] = '"第一个三"';
					break;
				case 3:
					$allRecord[$key]['des'] = '"第二个三"';
					break;
				case 4:
					$allRecord[$key]['des'] = '"嘻"字';
					break;
				case 5:
					$allRecord[$key]['des'] = '"游"字';
					break;
				case 6:
					$allRecord[$key]['des'] = '"季"字';
					break;
			}			
		}
		$this->assign('allRecord',$allRecord);
		
		//我的寻字记录
		$fromRecord = M('wx_gamerecord as gr')->join('33_wx_user as u on u.wx_openid=gr.from_user')->where('to_user="'.$wx_openid.'" and to_user <> from_user')->order('record_id desc')->select();
		foreach($fromRecord as $key=>$value){
			switch($value['status']){
				case 1:
					$fromRecord[$key]['des'] = '"哈哈一只"';
					break;
				case 2:
					$fromRecord[$key]['des'] = '"第一个三"';
					break;
				case 3:
					$fromRecord[$key]['des'] = '"第二个三"';
					break;
				case 4:
					$fromRecord[$key]['des'] = '"嘻"字';
					break;
				case 5:
					$fromRecord[$key]['des'] = '"游"字';
					break;
				case 6:
					$fromRecord[$key]['des'] = '"季"字';
					break;
			}			
		}
		$this->assign('fromRecord',$fromRecord);
	
		//活动总信息
		$tips['addnum'] = 830;
		$tips['add4'] = 28;
		$tips['add5'] = 15;
		$tips['total'] = M('wx_user')->count();   //参与人数
		$tips['status_1'] = M('wx_gameinfo')->where('status=1')->count();
		$tips['status_2'] = M('wx_gameinfo')->where('status=2')->count();
		$tips['status_3'] = M('wx_gameinfo')->where('status=3')->count();
		$tips['status_4'] = M('wx_gameinfo')->where('status=4')->count();
		$tips['status_5'] = M('wx_gameinfo')->where('status=5')->count();
		$tips['status_6'] = M('wx_gameinfo')->where('status=6')->count();
		$this->assign('tips',$tips);
		
		//奖品名称
		$pricename=array(
			'1' => '无',
			'2' => $priceList[4]['price_name'],
			'3' => $priceList[3]['price_name'],
			'4' => $priceList[2]['price_name'],
			'5' => $priceList[1]['price_name'],
			'6' => $priceList[0]['price_name']
		);
		$this->assign('pricename',$pricename);
		
		//ajax每2分钟获取一次(前端)
		$this->display();
    }
	
