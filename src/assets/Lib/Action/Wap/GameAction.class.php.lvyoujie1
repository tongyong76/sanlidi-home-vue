	//活动判断
	public function doGame(){
		//ajax from help
		//判断游戏
		/******
		input:
		  to_user varchar
		  from_user varchar
		return:
		  status int 状态 1晋级 2不变
		  price int 现阶段奖品
		******/
		$to_user = $_REQUEST['to_user'];
		$from_user = $_REQUEST['from_user'];
		
		//消息
		$notice=array(
			'1' => '寻到"哈哈一只"',
			'2' => '寻到"第一个三"',
			'3' => '寻到"第二个三"',
			'4' => '寻到"嘻"字',
			'5' => '寻到"游"字',
			'6' => '寻到"季"字'
		);
		
		//判断是否存在
		$existData['to_user'] = $to_user;
		$existData['from_user'] = $from_user;
		$is_exist = M('wx_gamerecord')->where('from_user="'.$wx_openid.'" and to_user="'.$wx_openid.'"')->find();
		//现在状态 1-6
		$status = M('wx_gameinfo')->where('wx_openid="'.$to_user.'"')->getField('status');
		$isOver = M('wx_gameinfo')->where('wx_openid="'.$to_user.'"')->getField('exchange_status');
		if($is_exist['record_id']){
			$this->ajaxReturn($status,'exist',1);//已助力，返回历史结果
		}elseif($isOver){
			$this->ajaxReturn($status,'over','Ta已兑换奖品');
		}elseif($status == 6){
			$this->ajaxReturn($status,'all','Ta已寻到全部图案');
		}else{						
			//插入记录
			$addData['from_user'] = $from_user;
			$addData['to_user'] = $to_user;
			$addData['status'] = $status;   //现有状态
			$addData['add_time'] = time();
			$newRecordId = M('wx_gamerecord')->add($addData);
			
			//载入预设奖品  摇奖
			$priceInfo = M('wx_gameprice')->where('price_status="'.$status.'"')->find();
			//if($priceInfo['price_num'] > $priceInfo['price_now']){
			//随机数
			$res = rand(1,$priceInfo['price_percent']);
			if($res == 1 and ($status <> 5)){
				//晋级 dosth.
				$newStatus = $status+1;
				M('wx_gamerecord')->where('record_id='.$newRecordId)->setfield('status',$newStatus);
				M('wx_gamerecord')->where('record_id='.$newRecordId)->setfield('is_update',1);
				$newData['status'] = $newStatus;
				$newData['last_record'] = $newRecordId;
				M('wx_gameinfo')->where('wx_openid="'.$to_user.'"')->save($newData);
				
				$this->ajaxReturn($newStatus,'update',$notice[$newStatus]);
			}else{
				//晋级失败
				$this->ajaxReturn((int)$status,'keep',$notice[$status]);
			}
			// }else{
				// //非法操作。直接返回失败
				// $this->ajaxReturn($status,'fail',1);
			// }
			
		}
	}
	
	//完善兑奖信息
	public function completeExchangeInfo(){
		$game_id = $_REQUEST['game_id'];
		$gameInfo = M('wx_gameinfo')->where('game_id='.$game_id)->find();
		$priceInfo = M('wx_gameprice')->where('price_status='.$gameInfo['status'])->find();
		$exdata['real_name'] = $_REQUEST['real_name'];
		$exdata['phone_number'] = $_REQUEST['phone_number'];
		$exdata['shop_id'] = $_REQUEST['shop_id'];
		$exdata['exchange_time'] = time();
		$exdata['exchange_ip'] = getClientIp();
		$exdata['exchange_status'] = 1;
		if(!$gameInfo['wx_openid']){
			$this->ajaxReturn($exist,'fail',0);
		}else{
			if($priceInfo['price_num'] > $priceInfo['price_now']){
				M('wx_gameinfo')->where('game_id='.$game_id)->save($exdata);
				//更新库存
				M('wx_gameprice')->where('price_status='.$gameInfo['status'])->setInc('price_now');
				$this->ajaxReturn('','success',1);	
			}else{
				$this->ajaxReturn('该奖品库存为0，明天再来看看！','none',0);
			}
			
		}		
	}
	
